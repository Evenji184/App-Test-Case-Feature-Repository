COMPOSE_PROJECT_NAME=app-feature-repository

# Database container
MYSQL_USER=evenji
MYSQL_PASSWORD=evenji
MYSQL_DB=app_feature_repository
MYSQL_PORT=3306

# Backend application
APP_NAME=APP Feature Repository Backend
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8001

SECRET_KEY=change-this-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Use the Docker service name as the database host inside containers.
DATABASE_URL=mysql://evenji:evenji@mysql:3306/app_feature_repository

LOG_LEVEL=INFO
LOG_JSON=false

# Frontend service address (used for auto-generating CORS origins)
FRONTEND_HOST=localhost
FRONTEND_PORT=5173
FRONTEND_SCHEME=http

# CORS origins: explicit config takes priority, comma-separated; leave empty to auto-generate from FRONTEND_*
# Example: CORS_ORIGINS=http://localhost:5173,http://192.168.1.100:5173
CORS_ORIGINS=

# IP access whitelist: comma-separated; leave empty to allow all IPs
# Example: IP_WHITELIST=127.0.0.1,192.168.1.0/24
IP_WHITELIST=

# Frontend / reverse proxy
FRONTEND_PORT=3000
NGINX_PORT=80
