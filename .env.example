COMPOSE_PROJECT_NAME=app-feature-repository

# Database container (service name kept as mysql for parent task compatibility)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_feature_repository
POSTGRES_PORT=5432

# Backend application
APP_NAME=APP Feature Repository Backend
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

SECRET_KEY=change-this-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Use the Docker service name as the database host inside containers.
DATABASE_URL=postgresql://postgres:postgres@mysql:5432/app_feature_repository

LOG_LEVEL=INFO
LOG_JSON=false

# Frontend / reverse proxy
FRONTEND_PORT=3000
NGINX_PORT=80
CORS_ORIGINS=["http://localhost:3000","http://localhost:80"]

